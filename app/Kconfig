source "Kconfig.zephyr"

menu "LNH Nordic"

config APP_WIFI_SSID
	string "Wi-Fi SSID"
	default ""

config APP_WIFI_PSK
	string "Wi-Fi password"
	default ""

config APP_WIFI_SECURITY
	string "Wi-Fi security mode"
	default "psk"
	help
	  Supported values: none, psk, psk-sha256, sae.

config APP_WIFI_TIMEOUT_MS
	int "Overall Wi-Fi timeout in milliseconds"
	default 90000
	range 1000 600000

config APP_WIFI_RETRY_INTERVAL_MS
	int "Wi-Fi reconnect retry interval in milliseconds"
	default 5000
	range 1000 600000
	help
	  Retry cadence used by the network supervisor after startup or runtime
	  network degradation.

config APP_REACHABILITY_HOST
	string "Hostname used for post-connect reachability check"
	default "example.com"

config APP_RECOVERY_WATCHDOG_TIMEOUT_MS
	int "Recovery watchdog timeout in milliseconds"
	default 30000
	range 1000 600000
	help
	  Hardware watchdog timeout serviced by the recovery manager only while
	  supervised execution paths remain inside their allowed windows.

config APP_RECOVERY_DEGRADED_PATIENCE_MS
	int "Recovery degraded patience window in milliseconds"
	default 120000
	range 1000 3600000
	help
	  Maximum continuous degraded or no-progress window before recovery
	  treats the condition as confirmed stuck.

config APP_RECOVERY_STABLE_WINDOW_MS
	int "Recovery stable-run clearing window in milliseconds"
	default 30000
	range 1000 600000
	help
	  Acceptable-runtime duration required before a prior recovery incident is
	  considered cleared.

config APP_RECOVERY_COOLDOWN_MS
	int "Recovery anti-thrash cooldown in milliseconds"
	default 180000
	range 1000 3600000
	help
	  Minimum suppression window after a recovery-triggered reboot before
	  another escalation may be considered.

config APP_PERSISTENCE_LAYOUT_VERSION
	int "Persistent configuration layout version"
	default 1
	range 1 255
	help
	  Schema layout version for the persisted configuration contracts.

config APP_RELAY_REBOOT_POLICY_DEFAULT
	int "Clean-device relay reboot policy"
	default 0
	range 0 2
	help
	  0 keeps the relay safely off after reboot until runtime configuration is
	  saved. 1 restores the last desired relay state. 2 ignores the last desired
	  state and leaves runtime relay control to later boot logic.

config APP_ADMIN_USERNAME
	string "Admin username"
	default ""

config APP_ADMIN_PASSWORD
	string "Admin password"
	default ""

config APP_PANEL_PORT
	int "Local control panel HTTP port"
	default 80
	range 1 65535
	help
	  Plain HTTP port exposed by the device on the local LAN for the Phase 5
	  control panel shell.

config APP_PANEL_MAX_SESSIONS
	int "Maximum concurrent panel sessions"
	default 4
	range 1 8
	help
	  Maximum number of concurrent RAM-only browser sessions allowed for the
	  single local operator account.

config APP_PANEL_LOGIN_FAILURE_LIMIT
	int "Wrong-password attempts before cooldown"
	default 5
	range 1 20
	help
	  Consecutive wrong-password attempts allowed before the panel enters a
	  temporary login cooldown.

config APP_PANEL_LOGIN_COOLDOWN_MS
	int "Panel login cooldown in milliseconds"
	default 30000
	range 1000 600000
	help
	  Cooldown applied after repeated wrong-password attempts.

endmenu
